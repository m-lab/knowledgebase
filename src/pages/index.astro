---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';
import { url } from '../utils';

const allArticles = await getCollection('articles', ({ data }) => !data.standalone);
const starterArticles = allArticles
  .filter(a => a.data.starter)
  .sort((a, b) => {
    const ao = a.data.order ?? Infinity;
    const bo = b.data.order ?? Infinity;
    return ao - bo;
  });

function slug(id: string) { return id.replace(/\.mdx?$/, ''); }
---

<Base>
  <!-- Hero -->
  <div class="hero">
    <h1>{SITE.title}</h1>
    <p>{SITE.tagline}</p>
    <a href={url('/browse/')} class="hero__browse-btn">Browse all articles →</a>
  </div>

  <!-- Starter articles grid -->
  <div class="starter-section">
    <div class="starter-section__header">
      <h2>Get started</h2>
      <p>Guides covering the essentials of M-Lab data, measurement tools, and how to run your own node.</p>
    </div>

    <div class="article-grid" id="article-grid">
      {starterArticles.map(article => (
        <div class="article-grid__item">
          <div class="article-card">
            <a href={url(`/${slug(article.id)}/`)} class="article-card__link">{article.data.title}</a>
            {article.data.description && (
              <p class="article-card__desc">{article.data.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="starter-section__footer">
      <a href={url('/browse/')} class="browse-link">
        View all articles, search, and filter by topic →
      </a>
    </div>
  </div>
</Base>

<style>
  .hero__browse-btn {
    display: inline-block;
    margin-top: var(--sp4);
    padding: var(--sp3) var(--sp6);
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: var(--radius-lg);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background var(--transition), border-color var(--transition);
  }
  .hero__browse-btn:hover {
    background: rgba(255,255,255,0.25);
    border-color: rgba(255,255,255,0.6);
    text-decoration: none;
  }

  .starter-section {
    max-width: var(--max-width);
    margin: var(--sp10) auto var(--sp16);
    padding: 0 var(--sp6);
  }
  .starter-section__header {
    margin-bottom: var(--sp8);
  }
  .starter-section__header h2 {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: var(--sp2);
    letter-spacing: -0.02em;
  }
  .starter-section__header p {
    color: var(--color-muted);
    font-size: 1rem;
  }

  /* Override the global .article-grid margin when inside starter-section */
  .starter-section .article-grid {
    margin-bottom: var(--sp8);
  }

  .starter-section__footer {
    text-align: center;
    padding-top: var(--sp4);
    border-top: 1px solid var(--color-border);
  }
  .browse-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
  }
  .browse-link:hover {
    text-decoration: underline;
  }
</style>
